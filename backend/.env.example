NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
DNS_SERVERS=1.1.1.1,8.8.8.8

JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=10
UPLOADS_DIR=uploads

# Optional: seed admin
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@12345

# Optional: seed demo students
SEED_STUDENT_COUNT=5
SEED_STUDENT_PASSWORD=Student@12345
SEED_STUDENT_DOMAIN=demo.edu
SEED_STUDENT_NAME_PREFIX=Student
SEED_STUDENT_EMAIL_PREFIX=student
SEED_STUDENT_SUBJECTS=Mathematics,Physics,Chemistry,DBMS,OS

# Optional: full demo content (marks + attendance + assignments)
SEED_DEMO_DOMAIN=demo.edu
SEED_FACULTY_PASSWORD=Faculty@12345
SEED_DEMO_SUBJECTS=Mathematics,Physics,Chemistry,DBMS,OS,Computer Networks
SEED_DEMO_SEED=42
